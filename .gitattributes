# Normalise line endings. Let Git decide for text files...
* text=auto

# ...but shell scripts MUST stay LF or they break on Linux / Raspberry Pi / macOS.
*.sh      text eol=lf
*.command text eol=lf

# Treat these as binary (no line-ending munging, no diff noise).
*.png binary
*.ico binary
*.gz  binary
*.db  binary
